{
  "manifest_version": 3,
  "name": "Quick Colour Buttons for Gmail",
  "description": "Adds four one-click text-colour buttons to Gmail compose.",
  "version": "2.4.1",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "color_blue": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "mac": "MacCtrl+Shift+1"
      },
      "description": "Apply Blue Color"
    },
    "color_green": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "mac": "MacCtrl+Shift+2"
      },
      "description": "Apply Green Color"
    },
    "color_red": {
      "suggested_key": {
        "default": "Ctrl+Shift+3",
        "mac": "MacCtrl+Shift+3"
      },
      "description": "Apply Red Color"
    },
    "color_orange": {
      "suggested_key": {
        "default": "Ctrl+Shift+4",
        "mac": "MacCtrl+Shift+4"
      },
      "description": "Apply Orange Color"
    },
    "color_grey": {
      "description": "Apply Grey Color"
    }
  }
}