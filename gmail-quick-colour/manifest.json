{
  "manifest_version": 3,
  "name": "Quick Colour Buttons for Gmail",
  "description": "Adds four one-click text-colour buttons to Gmail compose.",
  "version": "2.4.2",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "color_blue": {
      "suggested_key": {
        "default": "Alt+1",
        "mac": "Alt+1"
      },
      "description": "Apply Blue Color"
    },
    "color_green": {
      "suggested_key": {
        "default": "Alt+2",
        "mac": "Alt+2"
      },
      "description": "Apply Green Color"
    },
    "color_red": {
      "suggested_key": {
        "default": "Alt+3",
        "mac": "Alt+3"
      },
      "description": "Apply Red Color"
    },
    "color_orange": {
      "suggested_key": {
        "default": "Alt+4",
        "mac": "Alt+4"
      },
      "description": "Apply Orange Color"
    },
    "color_grey": {
      "description": "Apply Grey Color"
    }
  }
}